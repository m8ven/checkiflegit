---
interface Props {
  tier: string;
  label: string;
  summary: string;
  score: number | null;
}
const { tier, label, summary, score } = Astro.props;
---
<section class={`verdict ${tier}`} aria-label="Overall verdict">
  <div class="verdict__badge">
    <span class="verdict__score">{score ?? '—'}</span>
    {score != null && <span class="verdict__outof">/ 100</span>}
  </div>
  <div class="verdict__main">
    <div class="verdict__heading">
      <span class="verdict__dot" aria-hidden="true"></span>
      <h2 class="verdict__label">{label}</h2>
    </div>
    <p class="verdict__summary">{summary}</p>
  </div>
</section>
