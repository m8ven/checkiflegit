---
interface Signal { status: string; detail: string; value?: any; }
interface Props { signals: Record<string, Signal>; }
const { signals } = Astro.props;

const LABELS: Record<string, string> = {
  http: 'Website loads',
  platform: 'E-commerce platform',
  domainAge: 'Domain age',
  ssl: 'SSL / HTTPS security',
  pages: 'Contact & policy pages',
  contact: 'Business contact info',
  reviews: 'Third-party reviews',
  social: 'Social media presence',
};
const ORDER = ['http', 'platform', 'domainAge', 'ssl', 'pages', 'contact', 'reviews', 'social'];
const rows = ORDER.filter((k) => signals[k]).map((k) => ({ key: k, ...signals[k] }));
---
<ul class="signals">
  {rows.map((s) => (
    <li class={`signal signal--${s.status}`}>
      <span class="signal__icon" aria-hidden="true">
        {s.status === 'pass' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        )}
        {s.status === 'warn' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        )}
        {s.status === 'fail' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        )}
        {s.status === 'unknown' && (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        )}
      </span>
      <div class="signal__text">
        <span class="signal__name">{LABELS[s.key] ?? s.key}</span>
        <span class="signal__detail">{s.detail}</span>
      </div>
    </li>
  ))}
</ul>
