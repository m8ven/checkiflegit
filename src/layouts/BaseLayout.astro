---
import '../styles/global.css';
import { AD_CLIENT, adsEnabled } from '../adConfig';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  canonical?: string;
  jsonLd?: unknown;
}
const { title, description = '', noindex = false, canonical, jsonLd } = Astro.props;
// Embed JSON-LD safely (escape "<" so a payload can't break out of the script).
const jsonLdString = jsonLd ? JSON.stringify(jsonLd).replace(/</g, '\\u003c') : null;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const year = new Date().getFullYear();
const GA_ID = 'G-E2XMY17PT9';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" />

    {/* Google Analytics 4 (gtag.js) — loads site-wide on every page. */}
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
    <script is:inline define:vars={{ GA_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {jsonLdString && <script type="application/ld+json" set:html={jsonLdString} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />

    {/* Display-ad loader — only emitted once AD_CLIENT is set in src/adConfig.ts. */}
    {adsEnabled && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${AD_CLIENT}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/">
          <span class="brand__mark" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V5l-8-3Z"/><path d="m9 12 2 2 4-4"/></svg>
          </span>
          <span class="brand__name">Check<i>If</i>Legit</span>
        </a>
        <nav class="site-header__nav">
          <a class="site-header__link" href="/search">Search</a>
          <a class="site-header__link" href="/">All stores</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>
          CheckIfLegit publishes automated trust-signal summaries built from publicly
          available information. These are not definitive judgements of any business and
          do not constitute legal, financial, or professional advice. Always do your own
          research before purchasing.
        </p>
        <p style="margin-bottom:0">© {year} CheckIfLegit · <a href="/about">About &amp; methodology</a></p>
      </div>
    </footer>
  </body>
</html>
